# Bull — API credentials template
# Local dev: copy this file to .env and fill in your keys.
# Claude Desktop cloud routines: set these as environment variables
# in the routine's environment settings instead — no .env file needed.

# Alpaca (paper trading)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Perplexity (news sentiment research)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ClickUp (trade alerts + daily reports)
CLICKUP_API_KEY=your_clickup_api_key_here
CLICKUP_LIST_ID=your_clickup_list_id_here
